{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["./**/*.ts"],
    "exclude": []
}
